# =============================================
# FLUX Marketing - Variáveis de Ambiente
# =============================================
# Copie este arquivo para .env e preencha os valores

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Meta / Instagram ---
# Crie em: https://developers.facebook.com/apps
META_APP_ID=seu_app_id_aqui
META_APP_SECRET=seu_app_secret_aqui

# --- Google OAuth ---
# Crie em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret_aqui

# --- Google Ads ---
# Solicite em: https://ads.google.com/nav/selectaccount?authuser=0
GOOGLE_ADS_DEVELOPER_TOKEN=seu_developer_token_aqui

# --- URLs (Railway preenche automaticamente após o deploy) ---
BACKEND_URL=https://seu-backend.railway.app
FRONTEND_URL=https://seu-frontend.railway.app
